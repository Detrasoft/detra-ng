{
  "name": "@detrasoft.com/detra-ng",
  "version": "0.5.0",
  "description": "DetraSoft Angular Design System — standalone components com CSS puro para Angular 17-20",
  "keywords": [
    "angular",
    "design-system",
    "components",
    "ui",
    "detrasoft",
    "standalone"
  ],
  "license": "MIT",
  "author": {
    "name": "DetraSoft",
    "url": "https://detrasoft.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/detrasoft/detra-ng.git"
  },
  "bugs": {
    "url": "https://github.com/detrasoft/detra-ng/issues"
  },
  "homepage": "https://github.com/detrasoft/detra-ng#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "ng-packagr -p projects/detra-ng/ng-package.json",
    "build:watch": "ng-packagr -p projects/detra-ng/ng-package.json --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "echo \"No lint configured\" && exit 0",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:beta": "npm run build && npm version prerelease --preid=beta && npm publish --tag=beta --access=public",
    "publish:next": "npm run build && npm version prerelease --preid=next && npm publish --tag=next --access=public",
    "publish:latest": "npm run build && npm publish --access=public",
    "pack": "npm pack"
  },
  "peerDependencies": {
    "@angular/animations": ">=17.0.0 <21.0.0",
    "@angular/cdk": ">=17.0.0 <21.0.0",
    "@angular/common": ">=17.0.0 <21.0.0",
    "@angular/compiler": ">=17.0.0 <21.0.0",
    "@angular/core": ">=17.0.0 <21.0.0",
    "@angular/forms": ">=17.0.0 <21.0.0",
    "@angular/platform-browser": ">=17.0.0 <21.0.0",
    "rxjs": ">=7.0.0",
    "tslib": "^2.6.0",
    "zone.js": ">=0.13.0"
  },
  "dependencies": {
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@types/node": "^20.0.0",
    "ng-packagr": "^20.0.0",
    "rimraf": "^5.0.0",
    "rxjs": "~7.8.0",
    "typescript": "~5.8.0",
    "zone.js": "~0.15.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/detra-ng/index.d.ts",
      "default": "./dist/detra-ng/fesm2022/detrasoft.com-detra-ng.mjs"
    },
    "./base/*": "./dist/detra-ng/base/*",
    "./dist/detra-ng/base/*": "./dist/detra-ng/base/*",
    "./tokens/*": "./dist/detra-ng/tokens/*",
    "./dist/detra-ng/tokens/*": "./dist/detra-ng/tokens/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
