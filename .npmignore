# Source (somente dist é publicado)
/projects
/src

# Configurações
/tsconfig.json
/tsconfig.build.json
/.eslintrc.json
/.editorconfig
/.prettierrc
/.prettierignore

# Scripts internos (não são runtime)
/scripts
/prepublish.mjs

# Documentação interna (NÃO publicar)
/AUDIT-REPORT.md
/NPM-PUBLISH-GUIDE.md
/BUILD-PIPELINE.md

# Secrets / config local
/.npmrc
/.env
/.env.*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.idea
.vscode
.DS_Store
Thumbs.db

# CI / GitHub
/.github
.git
.gitignore

# Tests
**/*.spec.ts
**/*.spec.tsx
**/karma.conf.js
**/jest.config.js
**/coverage

# Dependências (não publicar)
/node_modules

# Build artifacts que não devem ir pro pacote
*.tsbuildinfo
